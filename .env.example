COMPOSE_PROJECT_NAME=letta-hybrid

# Option A deployment model:
# - pinned upstream Letta image
# - prebuilt Agent Platform API image from GHCR
LETTA_SERVER_IMAGE=letta/letta:0.16.7
AGENT_PLATFORM_API_IMAGE=ghcr.io/wenjun-mao/agent-platform-api:latest

LETTA_PG_USER=letta
LETTA_PG_PASSWORD=letta
LETTA_PG_DB=letta
LETTA_DB_HOST=letta_db
LETTA_PG_PORT=5432
LETTA_REDIS_HOST=redis
LETTA_REDIS_PORT=6379

LETTA_API_PORT=8283
LETTA_ADE_PORT=8083
LETTA_BASE_URL=http://localhost:8283
LETTA_DEBUG=True

# ---------- Letta Upstream Bootstrap (used by letta_server) ----------
LMSTUDIO_BASE_URL=http://host.docker.internal:1234

# ---------- OpenAI-Compatible Remote Provider For Letta ----------
OPENAI_API_BASE=https://ark.cn-beijing.volces.com/api/v3
OPENAI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
OPENAI_API_KEY=replace_with_your_ark_api_key

# Optional bootstrap handles used by some Letta image versions.
DOUBAO_CHAT_MODEL=doubao-seed-1-8-251228
LETTA_MODEL_HANDLE=openai-proxy/doubao-seed-1-8-251228

# ---------- Letta Embedding Defaults ----------
LETTA_DEFAULT_EMBEDDING_HANDLE=lmstudio_openai/text-embedding-qwen3-embedding-0.6b

# Backward-compatible alias for older startup scripts.
LETTA_EMBEDDING_HANDLE=lmstudio_openai/text-embedding-qwen3-embedding-0.6b

# ---------- ADE Shared Model Catalog (used by agent_platform_api) ----------
# `api_key_env` is resolved inside agent_platform_api.
# `api_key_secret` is checked first at /run/secrets/<name>.
# Leave `UNSLOTH_API_KEY` empty if the local source does not require auth.
UNSLOTH_API_KEY=
AGENT_PLATFORM_MODEL_SOURCES=[{"id":"local_unsloth","label":"Local Unsloth Studio","base_url":"http://host.docker.internal:1234/v1","kind":"openai-compatible","enabled_for":["chat","comment"],"letta_handle_prefix":"lmstudio_openai","api_key_env":"UNSLOTH_API_KEY","api_key_secret":"unsloth-api-key"},{"id":"ark","label":"Volcengine Ark","base_url":"https://ark.cn-beijing.volces.com/api/v3","kind":"openai-compatible","enabled_for":["chat","comment"],"letta_handle_prefix":"openai-proxy","api_key_env":"OPENAI_API_KEY","api_key_secret":"ark-api-key"}]

# ---------- Comment Runtime Tuning (used by agent_platform_api) ----------
AGENT_PLATFORM_COMMENTING_TIMEOUT_SECONDS=60
AGENT_PLATFORM_COMMENTING_MAX_TOKENS=0
AGENT_PLATFORM_COMMENTING_TASK_SHAPE=compact

