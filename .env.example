COMPOSE_PROJECT_NAME=letta-hybrid

# Local-build deployment model:
# - pinned upstream Letta image
# - first-party ADE services built from this checkout
LETTA_SERVER_IMAGE=letta/letta:0.16.7

LETTA_PG_USER=letta
LETTA_PG_PASSWORD=letta
LETTA_PG_DB=letta
LETTA_DB_HOST=letta_db
LETTA_PG_PORT=5432
LETTA_REDIS_HOST=redis
LETTA_REDIS_PORT=6379

LETTA_API_PORT=8283
LETTA_ADE_PORT=8083
LETTA_BASE_URL=http://localhost:8283
LETTA_DEBUG=True

# ---------- Letta Upstream Bootstrap (used by letta_server) ----------
# Letta now talks to the first-party model_router as its one OpenAI-compatible provider.
# `1234` remains reserved for LM Studio standby. It can be offline during normal llama-server use.
LMSTUDIO_BASE_URL=http://host.docker.internal:1234

# ---------- External Provider Secrets (used by model_router upstreams) ----------
OPENAI_API_BASE=https://ark.cn-beijing.volces.com/api/v3
OPENAI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
OPENAI_API_KEY=replace_with_your_ark_api_key

# Optional bootstrap handles used by some Letta image versions.
DOUBAO_CHAT_MODEL=doubao-seed-1-8-251228
LETTA_MODEL_HANDLE=openai-proxy/local_llama_server::gemma4

# ---------- Letta Embedding Defaults ----------
LETTA_DEFAULT_EMBEDDING_HANDLE=letta/letta-free

# Backward-compatible alias for older startup scripts.
LETTA_EMBEDDING_HANDLE=letta/letta-free

# ---------- Unified Model Router (canonical ADE model source of truth) ----------
# `api_key_env` is resolved inside model_router.
# `api_key_secret` is checked first at /run/secrets/<name>.
# `8081` is the active llama-server source. `100.64.35.71:8000` is the DGX/vLLM source.
# `2234` Unsloth Studio and `1234` LM Studio are standby examples.
# `LLAMA_SERVER_API_KEY` falls back to `UNSLOTH_API_KEY` for one transition round.
# /v1/models exposes Agent Studio-safe models to Letta. ADE modules use /v1/router/model-catalog.
# Edit source definitions in config/model_router_sources.json and model defaults in config/model_router_model_profiles.json.
MODEL_ROUTER_API_KEY=replace_with_local_router_key
MODEL_ROUTER_CACHE_TTL_SECONDS=30
MODEL_ROUTER_DISCOVERY_TIMEOUT_SECONDS=5
MODEL_ROUTER_REQUEST_TIMEOUT_SECONDS=600
LLAMA_SERVER_API_KEY=
UNSLOTH_API_KEY=
MODEL_ROUTER_SOURCES_FILE=config/model_router_sources.json
MODEL_ROUTER_MODEL_PROFILES_FILE=config/model_router_model_profiles.json
AGENT_PLATFORM_MODEL_ROUTER_BASE_URL=http://model_router:8290

# ---------- Persona Library Storage (used by agent_platform_api) ----------
# Personas are stored in SQLite for runtime CRUD/search. Seed JSONL is loaded only when the DB is empty.
AGENT_PLATFORM_PERSONA_DB_PATH=data/personas/personas.sqlite3
AGENT_PLATFORM_PERSONA_SEED_JSONL_PATH=agent_platform_api/seed_data/personas.jsonl

# ---------- Comment Runtime Tuning (used by agent_platform_api) ----------
AGENT_PLATFORM_COMMENTING_TIMEOUT_SECONDS=60
AGENT_PLATFORM_COMMENTING_MAX_TOKENS=0
AGENT_PLATFORM_COMMENTING_TASK_SHAPE=classic
AGENT_PLATFORM_COMMENTING_CACHE_PROMPT=false
AGENT_PLATFORM_COMMENTING_TEMPERATURE=0.6
AGENT_PLATFORM_COMMENTING_TOP_P=1.0
AGENT_PLATFORM_COMMENTING_TOP_K=

# ---------- Label Runtime Tuning (used by agent_platform_api) ----------
AGENT_PLATFORM_LABELING_TIMEOUT_SECONDS=60
AGENT_PLATFORM_LABELING_MAX_TOKENS=1024
AGENT_PLATFORM_LABELING_REPAIR_RETRY_COUNT=1
AGENT_PLATFORM_LABELING_TEMPERATURE=0.0
AGENT_PLATFORM_LABELING_TOP_P=1.0
AGENT_PLATFORM_LABELING_TOP_K=

# ---------- Agent Studio Runtime Tuning (used by agent_platform_api) ----------
# Agent Studio sampling is optional and only applied at agent creation time.
# Leave blank to let Letta/router/provider defaults apply.
AGENT_PLATFORM_AGENT_STUDIO_TEMPERATURE=
AGENT_PLATFORM_AGENT_STUDIO_TOP_P=
AGENT_PLATFORM_AGENT_STUDIO_TOP_K=

