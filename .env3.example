COMPOSE_PROJECT_NAME=letta-hybrid
LETTA_ENV_FILE=.env3

# Option A deployment model:
# - pinned upstream Letta image
# - prebuilt dev_ui image from GHCR
LETTA_SERVER_IMAGE=letta/letta:0.16.7
DEV_UI_IMAGE=ghcr.io/wenjun-mao/letta-doubao-dev-ui:latest

LETTA_PG_USER=letta
LETTA_PG_PASSWORD=letta
LETTA_PG_DB=letta
LETTA_DB_HOST=letta_db
LETTA_PG_PORT=5432
LETTA_REDIS_HOST=redis
LETTA_REDIS_PORT=6379

LETTA_API_PORT=8283
LETTA_ADE_PORT=8083
LETTA_BASE_URL=http://localhost:8283
LETTA_DEBUG=True

# ---------- LM Studio (local OpenAI-compatible endpoint) ----------
LMSTUDIO_BASE_URL=http://host.docker.internal:1234

# ---------- Doubao / ARK (OpenAI-compatible endpoint) ----------
OPENAI_API_BASE=https://ark.cn-beijing.volces.com/api/v3
OPENAI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
OPENAI_API_KEY=replace_with_your_ark_api_key

# Optional bootstrap handles used by some Letta image versions.
DOUBAO_CHAT_MODEL=doubao-seed-1-8-251228
LETTA_MODEL_HANDLE=openai-proxy/doubao-seed-1-8-251228

# ---------- Defaults used when model/embedding is omitted ----------
LETTA_DEFAULT_LLM_HANDLE=lmstudio_openai/qwen3.5-27b
LETTA_DEFAULT_EMBEDDING_HANDLE=lmstudio_openai/text-embedding-qwen3-embedding-0.6b

# Backward-compatible alias for older startup scripts.
LETTA_EMBEDDING_HANDLE=lmstudio_openai/text-embedding-qwen3-embedding-0.6b
